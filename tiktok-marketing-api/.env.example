# TikTok App 憑證（Developer Portal 取得）
TIKTOK_APP_ID=your_app_id_here
TIKTOK_APP_SECRET=your_app_secret_here

# OAuth Callback URL（Vercel 部署後填入）
TIKTOK_ADVERTISER_REDIRECT_URI=https://your-project.vercel.app/api/advertiser-callback
TIKTOK_ACCOUNT_REDIRECT_URI=https://your-project.vercel.app/api/account-callback

# Google Sheets
GOOGLE_SERVICE_ACCOUNT_FILE=../service-account.json
GOOGLE_SHEET_ID=your_sheet_id_here
GOOGLE_SHEET_AD_TAB=TikTok廣告成效
GOOGLE_SHEET_VIDEO_TAB=TikTok影片數據
GOOGLE_SHEET_ANALYSIS_TAB=TikTok行銷分析
ANTHROPIC_API_KEY=your_anthropic_api_key_here
